{
  "name": "loggapprodesktoptaurifull",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:logo": "node scripts/sync-opening-logo.js",
    "predev": "node scripts/sync-opening-logo.js",
    "dev": "npx kill-port 7061 7062 2>nul & cls & vite --port 7061 --host",
    "dev:tauri": "node scripts/sync-opening-logo.js && tauri dev",
    "dev:web": "tauri dev",
    "start:web": "tauri dev",
    "local": "cls && set PORT=7062 && set NODE_OPTIONS=--max_old_space_size=4096 && react-scripts start",
    "prebuild": "node -e \"if(process.env.SKIP_ICON!=='1'){require('child_process').execSync('npm run icon',{stdio:'inherit'})}else{console.log('SKIP_ICON: icones ignorees')}\"",
    "build": "tsc -b && vite build && node scripts/clean-dist.js",
    "build:no-icon": "set SKIP_ICON=1&& npm run build",
    "tauri:build:no-icon": "set SKIP_ICON=1&& npx tauri build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "pub": "vite --open /pub.html --port 7072 --strictPort false",
    "tauri": "tauri",
    "icon": "node scripts/make-square-icon.js && npx tauri icon src-tauri/icons/logo-square.png"
  },
