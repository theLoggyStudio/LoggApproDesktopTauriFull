{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LoggAppro Desktop",
  "version": "0.1.0",
  "identifier": "com.loggappro.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:7061/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LoggAppro Desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../dist"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installMode": "perMachine"
      },
      "wix": {
        "fragmentPaths": ["./windows/fragments/firewall.wxs"]
      }
    }
  }
}
